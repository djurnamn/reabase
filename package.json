{
  "name": "reabase",
  "version": "0.1.0",
  "description": "Manage REAPER FX chains as reusable, updatable dependencies across projects",
  "type": "module",
  "bin": {
    "reabase": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "reaper",
    "daw",
    "audio",
    "fx-chain",
    "preset"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "yaml": "^2.8.2"
  }
}
